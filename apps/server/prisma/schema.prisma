generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  stellarAddress String   @unique
  role           Role     @default(SUBJECT)
  createdAt      DateTime @default(now())
  did            DID?
  wallets        Wallet[]

  @@map("users")
}

model Wallet {
  id         String   @id @default(uuid())
  userId     String
  publicKey  String   @unique
  walletType String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model DID {
  id        String   @id
  userId    String   @unique
  document  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dids")
}

model Issuer {
  id             String       @id @default(uuid())
  did            String       @unique
  stellarAddress String       @unique
  name           String
  registeredAt   DateTime     @default(now())
  active         Boolean      @default(true)
  onChainTxHash  String?
  credentials    Credential[]

  @@map("issuers")
}

model Credential {
  id             String           @id @default(uuid())
  issuerId       String
  subjectDID     String
  type           String[]
  claims         Json
  proof          Json
  credentialHash String           @unique
  issuedAt       DateTime         @default(now())
  expiresAt      DateTime?
  status         CredentialStatus @default(ACTIVE)
  onChainTxHash  String?
  issuer         Issuer           @relation(fields: [issuerId], references: [id])
  revocation     Revocation?
  zkProofs       ZKProof[]

  @@map("credentials")
}

model Revocation {
  id            String     @id @default(uuid())
  credentialId  String     @unique
  revokedAt     DateTime   @default(now())
  reason        String?
  onChainTxHash String?
  credential    Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@map("revocations")
}

model ZKProof {
  id            String              @id @default(uuid())
  subjectDID    String
  credentialId  String
  circuitId     String
  artifact      Json?
  generatedAt   DateTime?
  status        ProofStatus         @default(PENDING)
  verifications ProofVerification[]
  credential    Credential          @relation(fields: [credentialId], references: [id])

  @@map("zk_proofs")
}

model ProofVerification {
  id            String   @id @default(uuid())
  proofId       String
  verifierDID   String
  result        Boolean
  verifiedAt    DateTime @default(now())
  onChainTxHash String?
  metadata      Json?
  proof         ZKProof  @relation(fields: [proofId], references: [id])

  @@map("proof_verifications")
}

model Verification {
  id          String   @id @default(uuid())
  subjectDID  String
  verifierDID String
  policyId    String
  decision    String
  evaluatedAt DateTime @default(now())
  metadata    Json?

  @@map("verifications")
}

model SorobanEvent {
  id              String   @id @default(uuid())
  contractAddress String
  eventType       String
  payload         Json
  ledgerSequence  Int
  txHash          String
  indexedAt       DateTime @default(now())

  @@map("soroban_events")
}

model ProofRequest {
  id          String             @id @default(uuid())
  verifierDID String
  subjectDID  String?
  circuitId   String
  purpose     String
  callbackUrl String?
  expiresAt   DateTime
  status      ProofRequestStatus @default(PENDING)
  proofId     String?
  createdAt   DateTime           @default(now())

  @@map("proof_requests")
}

model VeriffSession {
  id           String   @id @default(uuid())
  userId       String
  sessionId    String   @unique  // Veriff session ID
  sessionUrl   String
  status       String   @default("created") // created | approved | declined | resubmission_requested | abandoned | expired
  credentialId String?  // set after VC is issued on approval
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("veriff_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  eventName  String
  actorDID   String
  subjectDID String?
  resourceId String
  timestamp  DateTime @default(now())
  metadata   Json

  @@map("audit_logs")
}

enum Role {
  SUBJECT
  ISSUER
  ADMIN
}

enum CredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum ProofStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum ProofRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}
